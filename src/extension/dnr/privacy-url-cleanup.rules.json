[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "redirect",
      "redirect": {
        "transform": {
          "queryTransform": {
            "removeParams": [
              "utm_source",
              "utm_medium",
              "utm_campaign",
              "utm_term",
              "utm_content",
              "utm_id",
              "fbclid",
              "gclid",
              "dclid",
              "msclkid",
              "mc_cid",
              "mc_eid"
            ]
          }
        }
      }
    },
    "condition": {
      "regexFilter": "^https?://.*[?&](utm_(source|medium|campaign|term|content|id)|fbclid|gclid|dclid|msclkid|mc_(cid|eid))=",
      "resourceTypes": [
        "main_frame"
      ]
    }
  }
]
